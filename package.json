{
  "name": "cloudrain",
  "version": "1.0.0",
  "description": "CloudRain - Plataforma de streaming para artistas independentes",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "serve:frontend": "npx serve frontend -p 5500 --no-clipboard",
    "dev:full": "concurrently \"npm run dev\" \"npm run serve:frontend\"",
    "seed:admin": "node backend/scripts/seed-admin.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "serve": "^14.2.1"
  }
}
